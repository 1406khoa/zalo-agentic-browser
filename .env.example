# ---- VNG MaaS (LLM) ----
MAAS_URL=https://mass-llm-aiplatform-dev.api.vngcloud.tech/v1/chat/completions
MAAS_MODEL=openai/gpt-4o-mini
MAAS_API_KEY=                 # from AI Platform > API Keys (shown once) — put the real value in .env (gitignored)

# ---- Zalo (zlapi, personal account) ----
# Get IMEI + COOKIES via the zlapi browser extension at https://chat.zalo.me
ZALO_PHONE=
ZALO_PASSWORD=
ZALO_IMEI=
ZALO_COOKIES=                 # JSON object string, e.g. {"cookie1":"val1",...}

# ---- Bot behaviour ----
BOT_TRIGGER=@ai               # text trigger keyword (case-insensitive)
BUFFER_SIZE=60                # group messages buffered for summarize/personality
RESPOND_TO_SELF=true          # respond to the bot account owner's own messages (loop-safe)
PORT=8080
